AUTH_SECRET=change-me-generate-with-openssl-rand
# Path-based tenants share one origin; AUTH_URL is set from the request Host.
AUTH_TRUST_HOST=true

# Auth0 (see docs/AUTH0_SETUP.md)
AUTH_AUTH0_ID=
AUTH_AUTH0_SECRET=
AUTH_AUTH0_ISSUER=https://YOUR_TENANT.us.auth0.com/
AUTH_AUTH0_AUDIENCE=https://api.whitelabel.local

ROOT_DOMAIN=whitelabel.com.br
NEXT_PUBLIC_ROOT_DOMAIN=whitelabel.com.br
NEXT_PUBLIC_API_URL=http://localhost:5247
# Optional: public R2/CDN host for next/image (same as MinhaApi R2:PublicBaseUrl host)
# NEXT_PUBLIC_CDN_URL=https://cdn.example.com

# Google Maps (Delivery areas): enable Maps JavaScript API in Google Cloud
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Dev local (manage app):
# http://manage.localhost:3000/              → lista de empresas
# http://manage.localhost:3000/cowboy-burger-67 → painel da empresa

# R2 credentials live in MinhaApi (appsettings / env), not in the Next app:
# R2__AccountId=
# R2__AccessKeyId=
# R2__SecretAccessKey=
# R2__BucketName=whitelabel
# R2__PublicBaseUrl=https://pub-xxxxx.r2.dev

# Stripe (account subscriptions) — configure in MinhaApi:
# Stripe__SecretKey=sk_test_...
# Stripe__WebhookSecret=whsec_...
# Stripe__PriceId=price_...
# Stripe__SuccessUrl=http://localhost:3000/account/billing?success=1
# Stripe__CancelUrl=http://localhost:3000/account/billing?canceled=1
# Stripe__PortalReturnUrl=http://localhost:3000/account/billing
# Local webhook: stripe listen --forward-to localhost:5247/webhooks/stripe
